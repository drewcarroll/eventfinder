# Application
APP_NAME=Event Swiper API
ENVIRONMENT=development
DEBUG=true

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/event_swiper

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Tavily
TAVILY_API_KEY=tvly-xxxxxxxx

# Geocoding (OpenStreetMap Nominatim — keyless; set an identifying
# User-Agent per Nominatim's usage policy)
GEOCODING_USER_AGENT=EventSwiper/0.1 (event-swiper)

# Firebase Admin (service account JSON path; leave blank to use ADC)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# CORS (comma-separated)
CORS_ORIGINS=*
